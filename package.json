{
  "name": "accident-scene-api",
  "version": "0.0.1",
  "description": "Accident Scene API",
  "author": "Joshua Uzor",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && npm run copy-templates",
    "copy-templates": "mkdir -p dist/src/shared/templates && (cp src/shared/templates/*.hbs dist/src/shared/templates/ 2>/dev/null || true)",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:staging": "NODE_ENV=staging pm2 startOrReload dist/ecosystem.config.js --watch",
    "start:prod": "NODE_ENV=production pm2 startOrReload dist/ecosystem.config.js --watch",
    "migrate:run": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo --name",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "migrate:create": "npx sequelize-cli migration:create --underscored --name",
    "migrate:rollback": "sequelize-cli db:migrate:undo:all --to",
    "build-lambda": "nest build --webpack --webpackPath webpack.config.js",
    "sls:offline": "NODE_TLS_REJECT_UNAUTHORIZED=0 serverless offline",
    "test:lambda": "ts-node test/local-lambda.ts",
    "sam:local": "sam local start-api",
    "sam:invoke": "sam local invoke NestJsFunction --event event.json",
    "deploy:console": "npm run package:lambda && echo 'Now upload lambda-deployment.zip to AWS Lambda Console'",
    "deploy": "npm run build && serverless deploy --stage ${NODE_ENV:-dev}",
    "deploy:package": "npm run build && serverless package",
    "seed:run": "sequelize-cli db:seed:all",
    "seed:create": "sequelize-cli seed:generate --name",
    "seed:undo": "sequelize-cli db:seed:undo --seed",
    "lint": "eslint \"{src,apps,libs,test,config}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "deploy:cdk": "bash scripts/deploy-cdk.sh",
    "deploy:staging": "STAGE=staging REGION=${REGION:-eu-north-1} npm run deploy:cdk",
    "logs:watch": "bash scripts/view-logs.sh production follow"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "@sentry/nestjs": "^10.53.1",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "nestjs-pino": "^4.6.1",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize-typescript": "^2.1.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
